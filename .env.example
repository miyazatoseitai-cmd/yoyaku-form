# LINE Messaging API（LINE Developers Consoleで取得）
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# サロンボードのログイン情報
SALONBOARD_EMAIL=your_salonboard_email@example.com
SALONBOARD_PASSWORD=your_salonboard_password

# サーバーポート（デフォルト: 3000）
PORT=3000
